# Скопировать в .env и заполнить: cp .env.example .env

# Telegram
BOT_TOKEN=

# Postgres в compose: тот же пароль, что в POSTGRES_PASSWORD (не меняйте только одну строку).
POSTGRES_PASSWORD=password
# Database — локально на хосте:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/assistant_db
# В Docker Compose (хост db, пользователь user, пароль = POSTGRES_PASSWORD):
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/assistant_db

# Redis — на хосте: redis://localhost:6379/0
# В Docker Compose:
REDIS_URL=redis://redis:6379/0

# OpenClaw Gateway (bootstrap-скрипт включает POST /v1/responses)
# Бот в Docker, Gateway на хосте того же сервера:
OPENCLAW_URL=http://host.docker.internal:18789
# Всё на хосте без Docker у бота:
# OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_API_KEY=
OPENCLAW_MODEL=openclaw
# Необязательно: x-openclaw-agent-id (см. docs.openclaw.ai/gateway/openresponses-http-api)
OPENCLAW_AGENT_ID=

# LLM routing
LLM_MODE=auto
# Глобальный primary, если у пользователя не задана оплаченная линия (billing_llm_line пусто): openclaw | openai | mock
PRIMARY_PROVIDER=mock
FALLBACK_PROVIDER=mock
# Триал: mock — без Ollama; ollama — нужен Ollama (профиль ollama в compose или хост)
TRIAL_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Ollama: на хосте http://localhost:11434; в compose с --profile ollama → http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# v1 BYO: ключи LLM — у пользователя; в .env только инфраструктура
# Шифрование пользовательских токенов OAuth в БД (сгенерировать, например: openssl rand -hex 32)
APP_ENCRYPTION_KEY=

# ЮKassa + HTTP API для вебхука (тот же процесс, что и бот)
BILLING_HTTP_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8080
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
# Куда вернётся пользователь после оплаты (часто ссылка на бота)
BILLING_RETURN_URL=https://t.me/
YUKASSA_CURRENCY=RUB
# Fallback plan в вебхуке, если в метаданных платежа нет plan
YUKASSA_PLAN=basic
# Сетка цен: линия (GPT / Claude / Gemini) × пакет токенов за период (basic=1M, standard=2M, pro=3M)
BILLING_GPT_BASIC_RUB=1300.00
BILLING_GPT_STANDARD_RUB=2700.00
BILLING_GPT_PRO_RUB=4000.00
BILLING_CLAUDE_BASIC_RUB=2000.00
BILLING_CLAUDE_STANDARD_RUB=3500.00
BILLING_CLAUDE_PRO_RUB=5000.00
BILLING_GEMINI_BASIC_RUB=500.00
BILLING_GEMINI_STANDARD_RUB=950.00
BILLING_GEMINI_PRO_RUB=1500.00
# В личном кабинете ЮKassa укажите URL: https://<ваш-домен>/webhooks/yookassa
WEBHOOK_URL=https://yourdomain.com/webhooks/yookassa

# Метрики: события в таблице bot_events; отчёт в Telegram-канал; JSON API
METRICS_ENABLED=true
METRICS_REPORT_ENABLED=false
# ID канала (часто -100…) или чата; бот должен быть админом канала с правом постить
METRICS_REPORT_CHAT_ID=
# Час UTC ежедневного отчёта (0–23)
METRICS_REPORT_HOUR_UTC=8
# true — отправить отчёт через ~15 с после старта (для проверки)
METRICS_REPORT_ON_START=false
# Секрет для GET /internal/metrics/summary (заголовок Authorization: Bearer …)
METRICS_INTERNAL_TOKEN=

# App
ADMIN_IDS=
# Один чат/канал для алертов команды (опционально). Иначе сообщения уходят каждому из ADMIN_IDS
ADMIN_TEAM_CHAT_ID=

# true — только whitelist + ADMIN_IDS (заполните INTERNAL_WHITELIST_IDS или выключите режим)
# false — любой пользователь Telegram может писать боту (удобно для быстрого теста на моках)
INTERNAL_TEST_MODE=false
INTERNAL_WHITELIST_IDS=
DAILY_MSG_LIMIT_BASIC=50
DAILY_MSG_LIMIT_STANDARD=150
DAILY_MSG_LIMIT_PRO=500
PAID_TOKEN_LIMIT_BASIC=1000000
PAID_TOKEN_LIMIT_STANDARD=2000000
PAID_TOKEN_LIMIT_PRO=3000000
TRIAL_DURATION_HOURS=24
TRIAL_MESSAGE_LIMIT=50
SOFT_DAILY_MESSAGE_LIMIT=3
PAID_FALLBACK_DAILY_MESSAGE_LIMIT=300
BTN_TRIAL=🪄 Познакомиться с OpenClaw
BTN_PLANS=💳 Тарифы и оплата
# true — в конце ответа LLM показывать provider/model (удобно при отладке)
SHOW_LLM_DEBUG_IN_REPLY=false

# Pricing (USD) — опционально, для будущих интеграций
PRICE_BASIC=12
PRICE_STANDARD=20
PRICE_PRO=35
