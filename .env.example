# Скопировать в .env и заполнить: cp .env.example .env

# Telegram
BOT_TOKEN=

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/dbname

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenClaw Gateway (включите POST /v1/responses в конфиге Gateway)
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_API_KEY=
OPENCLAW_MODEL=openclaw
# Необязательно: x-openclaw-agent-id (см. docs.openclaw.ai/gateway/openresponses-http-api)
OPENCLAW_AGENT_ID=

# LLM routing
LLM_MODE=auto
# Глобальный primary, если у пользователя не задана оплаченная линия (billing_llm_line пусто): openclaw | openai | mock
PRIMARY_PROVIDER=mock
FALLBACK_PROVIDER=mock
TRIAL_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# v1 BYO: ключи LLM — у пользователя; в .env только инфраструктура
# Шифрование пользовательских токенов OAuth в БД (сгенерировать, например: openssl rand -hex 32)
APP_ENCRYPTION_KEY=

# ЮKassa + HTTP API для вебхука (тот же процесс, что и бот)
BILLING_HTTP_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8080
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
# Куда вернётся пользователь после оплаты (часто ссылка на бота)
BILLING_RETURN_URL=https://t.me/
YUKASSA_CURRENCY=RUB
# Fallback plan в вебхуке, если в метаданных платежа нет plan
YUKASSA_PLAN=basic
# Сетка цен: линия (GPT / Claude / Gemini) × пакет токенов за период (basic=1M, standard=2M, pro=3M)
BILLING_GPT_BASIC_RUB=1300.00
BILLING_GPT_STANDARD_RUB=2700.00
BILLING_GPT_PRO_RUB=4000.00
BILLING_CLAUDE_BASIC_RUB=2000.00
BILLING_CLAUDE_STANDARD_RUB=3500.00
BILLING_CLAUDE_PRO_RUB=5000.00
BILLING_GEMINI_BASIC_RUB=500.00
BILLING_GEMINI_STANDARD_RUB=950.00
BILLING_GEMINI_PRO_RUB=1500.00
# В личном кабинете ЮKassa укажите URL: https://<ваш-домен>/webhooks/yookassa
WEBHOOK_URL=https://yourdomain.com/webhooks/yookassa

# App
ADMIN_IDS=
INTERNAL_TEST_MODE=true
INTERNAL_WHITELIST_IDS=
DAILY_MSG_LIMIT_BASIC=50
DAILY_MSG_LIMIT_STANDARD=150
DAILY_MSG_LIMIT_PRO=500
PAID_TOKEN_LIMIT_BASIC=1000000
PAID_TOKEN_LIMIT_STANDARD=2000000
PAID_TOKEN_LIMIT_PRO=3000000
TRIAL_DURATION_HOURS=24
TRIAL_MESSAGE_LIMIT=50
SOFT_DAILY_MESSAGE_LIMIT=3
PAID_FALLBACK_DAILY_MESSAGE_LIMIT=300
BTN_TRIAL=🪄 Познакомиться с OpenClaw
BTN_PLANS=💳 Тарифы и оплата

# Pricing (USD) — опционально, для будущих интеграций
PRICE_BASIC=12
PRICE_STANDARD=20
PRICE_PRO=35
