# Скопировать в .env и заполнить: cp .env.example .env

# Telegram
BOT_TOKEN=

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/dbname

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenClaw
OPENCLAW_URL=http://openclaw:3000
OPENCLAW_API_KEY=

# v1 BYO: ключи LLM — у пользователя; в .env только инфраструктура
# Шифрование пользовательских токенов OAuth в БД (сгенерировать, например: openssl rand -hex 32)
APP_ENCRYPTION_KEY=

# Billing (позже)
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
WEBHOOK_URL=https://yourdomain.com/webhook/payment

# App
ADMIN_IDS=
DAILY_MSG_LIMIT_BASIC=50
DAILY_MSG_LIMIT_STANDARD=150
DAILY_MSG_LIMIT_PRO=500

# Pricing (USD)
PRICE_BASIC=12
PRICE_STANDARD=20
PRICE_PRO=35
